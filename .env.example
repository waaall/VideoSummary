# VideoSummary 前端环境变量配置
# 复制此文件为 .env.local 并根据需要修改

# API 基础地址
VITE_API_BASE_URL=http://localhost:8765

# API 请求超时时间（毫秒）
VITE_API_TIMEOUT=300000

# 状态轮询间隔（毫秒）
VITE_POLLING_INTERVAL=2000

# 最大上传文件大小（字节）：默认 500MB
VITE_MAX_FILE_SIZE=524288000

# ==================== 前端默认设置（可选） ====================
# 设置页中可修改轮询间隔/请求超时/上传限制，存储于浏览器
