# VideoSummary 生产环境（Portal 集成）
# 统一固定到 /apps/video 路径体系

# 部署模式
VITE_BASE_PATH=/apps/video/
VITE_ROUTER_BASENAME=/apps/video
VITE_EMBEDDED=true
VITE_STORAGE_NS=video
VITE_COOKIE_PATH=/apps/video/

# API 基础地址（与 endpoint=/api/* 组装后为 /apps/video/api/*）
VITE_API_BASE_URL=/apps/video

# Bearer Token（可选，通常由 Portal 或运行时注入）
VITE_API_AUTH_TOKEN=

# 请求配置
VITE_API_TIMEOUT=300000
VITE_POLLING_INTERVAL=2000

# 上传限制
VITE_MAX_FILE_SIZE=524288000
