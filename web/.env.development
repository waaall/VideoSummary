# VideoSummary 开发环境
# 默认 standalone 开发；可按需改成 Portal 联调

# 部署模式（standalone 默认）
VITE_BASE_PATH=/
VITE_ROUTER_BASENAME=/
VITE_EMBEDDED=false
VITE_STORAGE_NS=video
VITE_COOKIE_PATH=/

# API 基础地址（开发联调可改为你的后端地址）
VITE_API_BASE_URL=http://localhost:8765
# 示例：VITE_API_BASE_URL=http://192.168.50.50:8765
# 示例（Portal 网关联调）：VITE_API_BASE_URL=/apps/video

# Bearer Token（可选）
VITE_API_AUTH_TOKEN=

# 请求配置
VITE_API_TIMEOUT=300000
VITE_POLLING_INTERVAL=2000

# 上传限制
VITE_MAX_FILE_SIZE=524288000
